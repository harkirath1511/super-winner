# Vercel AI Gateway (required)
AI_GATEWAY_API_KEY=

# Pinata (required) — get from https://app.pinata.cloud/developers/api-keys
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud

# Tavily search (required) — get from https://app.tavily.com
TAVILY_API_KEY=

# Session encryption secret — at least 32 random chars
SESSION_SECRET=change_me_to_a_long_random_secret_string_here

# Your app's public URL (for SIWE domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000
